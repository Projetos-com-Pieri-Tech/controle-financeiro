# Configurações do Servidor
PORT=3001
NODE_ENV=development

# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=controle_financeiro
DB_USER=postgres
DB_PASSWORD=postgres

# Configurações JWT
# IMPORTANTE: Use uma chave forte e única em produção!
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secure_jwt_secret_key_here_minimum_32_characters_recommended